{
    "name": "ziyoren/pay-sdk",
    "description": "Ziyoren Pay SDK for payment integration",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ziyoren Team",
            "email": "team@ziyoren.pay"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Ziyoren\\PaySdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ziyoren\\PaySdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src/"
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}